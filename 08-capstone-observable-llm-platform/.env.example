API_PORT=8010
LLM_PORT=8011
RAG_PORT=8012
OBSERVABILITY_PORT=8013

ENVIRONMENT=local
SERVICE_NAME=capstone-api-gateway

DATABASE_URL=postgresql://capstone:capstone@postgres:5432/capstone
REDIS_URL=redis://redis:6379/0

LLM_SERVICE_URL=http://llm-service:8011
RAG_SERVICE_URL=http://rag-service:8012
OBSERVABILITY_DB_PATH=/app/data/capstone_metrics.db

EMBEDDING_PROVIDER=hash
LLM_RUNTIME=mock
DEFAULT_MODEL=capstone-mock-llm
REQUEST_TIMEOUT_SECONDS=120
